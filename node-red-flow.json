        "props": [{ "p": "payload" }],
        "repeat": "3600",
        "crontab": "",
        "once": false,
        "onceDelay": 0,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 120,
        "y": 120,
        "wires": [["c_request"]]
    },

    {
        "id": "c_request",
        "type": "http request",
        "z": "tab_cleanup",
        "name": "DELETE /api/flights/stale",
        "method": "DELETE",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://127.0.0.1:3000/api/flights/stale",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 340,
        "y": 120,
        "wires": [["c_result"]]
    },

    {
        "id": "c_result",
        "type": "function",
        "z": "tab_cleanup",
        "name": "Log Cleanup Result",
        "func": "const result = msg.payload;\nconst deleted = result && result.deleted !== undefined ? result.deleted : '?';\nnode.status({ fill: 'green', shape: 'dot', text: 'Removed ' + deleted + ' stale records' });\nmsg.payload = { message: 'Cleanup complete', deleted: deleted, timestamp: new Date().toISOString() };\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 120,
        "wires": [["c_debug"]]
    },

    {
        "id": "c_debug",
        "type": "debug",
        "z": "tab_cleanup",
        "name": "Cleanup Log",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "",
        "statusType": "auto",
        "x": 800,
        "y": 120,
        "wires": []
    },

