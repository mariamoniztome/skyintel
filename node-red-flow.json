        "id": "n_prepare_auth",
        "type": "function",
        "z": "tab_main",
        "name": "Set OpenSky Auth",
        "func": "const clientId = \"mariatomejobs@gmail.com-api-client\";\nconst clientSecret = \"FRaOvSzA6JFdz0O2lxHhC8LDHOc2NWZF\";\n\nconst encoded = Buffer.from(\n    clientId + \":\" + clientSecret\n).toString(\"base64\");\n\nmsg.headers = {\n    Authorization: \"Basic \" + encoded\n};\n\nnode.status({\n    fill: \"green\",\n    shape: \"dot\",\n    text: \"Auth ready\"\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
